# Supabase — get these from your project dashboard → Settings → API
# These match the existing libby_live Supabase project credentials.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App URL (used for OAuth redirects and OpenRouter HTTP-Referer)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# OpenRouter — https://openrouter.ai/keys
# This is the SERVER-SIDE fallback key used when a user has no BYOK key set.
# Users can also enter their own key in Settings (stored in user_preferences).
# Without this AND without a user key, Libby falls back to rule-based responses.
OPENROUTER_API_KEY=sk-or-your-key-here

# Google OAuth — https://console.cloud.google.com → APIs & Services → Credentials
# Scopes: calendar.readonly, userinfo.email
# Redirect URI: $NEXT_PUBLIC_APP_URL/api/connectors/google-calendar/callback
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# GitHub OAuth — https://github.com/settings/applications/new
# Scopes: read:user repo
# Callback URL: $NEXT_PUBLIC_APP_URL/api/connectors/github/callback
# Note: users can also connect via Personal Access Token — no OAuth app needed for that path.
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
