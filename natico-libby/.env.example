# Supabase — Settings → API in your Supabase project dashboard
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App URL — used for OAuth redirect URIs and OpenRouter HTTP-Referer
NEXT_PUBLIC_APP_URL=http://localhost:3000

# OpenRouter — https://openrouter.ai/keys
# NOTE: This app uses BYOK (Bring Your Own Key) as the primary mode.
# Each user stores their own OpenRouter key in Settings → AI.
# This server-side variable is intentionally NOT used for user sessions.
# It is reserved for future admin/system tooling only. Leave blank for now.
# OPENROUTER_API_KEY=sk-or-...

# Google OAuth — https://console.cloud.google.com → APIs & Services → Credentials
# Required scopes: calendar.readonly, userinfo.email
# Authorized redirect URI: $NEXT_PUBLIC_APP_URL/api/connectors/google-calendar/callback
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# GitHub OAuth — https://github.com/settings/applications/new
# Required scopes: read:user, repo
# Callback URL: $NEXT_PUBLIC_APP_URL/api/connectors/github/callback
# Note: users may also connect via Personal Access Token without registering an OAuth app.
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
