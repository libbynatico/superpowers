# Supabase — get these from your project dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App URL (used for OAuth redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Google OAuth — create at console.cloud.google.com
# Scopes needed: calendar.readonly, userinfo.email
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# GitHub OAuth — create at github.com/settings/applications/new
# Scopes needed: read:user, repo (read-only)
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# Optional: Anthropic API key for Claude-powered Libby responses
# Without this key, Libby will use context-aware rule-based responses
# ANTHROPIC_API_KEY=sk-ant-...
